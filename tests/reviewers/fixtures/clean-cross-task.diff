+// Task 1 (user service)
+import { db } from "../db.js";
+export interface User { id: string; email: string }
+export async function getUser(id: string): Promise<User | null> {
+  const rows = await db.query<User>("SELECT id, email FROM users WHERE id = $1", [id]);
+  return rows[0] ?? null;
+}
