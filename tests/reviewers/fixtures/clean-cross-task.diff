+// Task 2 (order service) — userId is string, matching User.id from Task 1
+import { db } from "../db.js";
+import type { Order } from "./types";
+export async function getOrdersByUser(userId: string): Promise<Order[]> {
+  return db.query<Order>('SELECT user_id AS "userId", total FROM orders WHERE user_id = $1', [userId]);
+}
