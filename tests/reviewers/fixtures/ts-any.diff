+export function List({ items }: any) {
+  const [data, setData] = useState(items);
+  useEffect(() => {
+    fetch("/api/refresh").then((r) => r.json()).then(setData);
+  }, []);
+  return (
+    <ul>
+      {items.map((item, i) => (<li key={i}>{item.name}</li>))}
+    </ul>
+  );
+}
