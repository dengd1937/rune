+from typing import Sequence
+
+
+def merge_tags(tags: Sequence[str | None], prefix: list[str] | None = None) -> list[str]:
+    current = prefix if prefix is not None else []
+    names: list[str] = []
+    for tag in tags:
+        if tag is None:
+            continue
+        names.append(f"{tag}_{'_'.join(current)}")
+    return names
